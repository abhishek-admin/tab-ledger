{
  "manifest_version": 3,
  "name": "Tab Ledger",
  "description": "Tab Ledger: Save important tabs for later with AI-generated summaries. Never lose track of what matters",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "tabs",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icons32.png"
    }
  },
  "icons": {
    "32": "icons/icons32.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ]
}